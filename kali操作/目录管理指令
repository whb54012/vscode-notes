 ####几乎所有文件操作不写完整地址都会默认在当前目录下查找并进行操作,若文件不在当前目录将不会受到影响####
##文件就表示文件名加后缀,有些文件没有后缀就不加##
pwd; 显示当前处于哪个目录
#cd
cd ..;返回上一级目录
cd;单独回到户主目录
cd /;切换到根目录
cd -;返回到上次操作的目录
#ls
ls;列出当前的目录下的文件和子目录
ls -l;以长格式列出文件和目录详细信息
ls -a;列出当前所有文件和目录,包括隐藏文件
#tree
tree;将文件与目录以树形式展示出来
#which
which 文件/应用;将指定文件/应用的地址路径展示出来
#mkdir+rmdir
mkdir 目录名;创建新目录
rmdir 目录名;删除目录
#rm
rm 文件.类型;删除指定文件
rm -f 文件;强制删除文件,包括只可读文件
rm -r  文件夹;递归删除目录(文件夹及内部文件)
rm -rf 文件夹;递归并强制删除目录(文件夹),权限不足也可强行删除
rm /*;强制删除所有系统文件
#cp
cp 旧文件 新文件;将旧文件复制进新文件里面
cp -r(用于文件夹) 旧文件夹 新文件夹;将旧文件夹复制进新文件夹里面
#mv
mv 文件/文件夹旧名 新名;将文件和文件夹重命名
mv 文件/文件夹 新文件夹(新目录);将文件或文化夹转移至新文件夹(目录)
#echo
echo 内容> 文件;将新内容覆写进文件中,替代原内容
echo 内容>> 文件;将新内容换行追加进文件,不改变原内容
#cat
cat 文件;查看文件内容
#tail
tail -5(表示查看尾部五行) -f(持续跟踪显示文件内容) 文件 从倒数一行往前查找
#vim
vim 文件;直接对文件进行编辑,比echo更简便
打开文件按i进入编辑,按esc保存编辑
按:wq!+回车保存并推出vim模式,wq表示保存并退出,!表示强制操作
#tar
tar -cvf 新文件包.tar 文件/文件夹;将文件/文件夹打包进一个文件夹;
tar -xvf 文件包.tar; 将文件从打包文件中提取出来
tar -z/j/Jcvf 文件包.tar.gz/bz2/xz 文件/文件夹;将文件夹打包后进行压缩
z → gzip 压缩(最常用)=gz
-j → bzip2 压缩=bz2
-J → xz 压缩(压得更小，但慢)=xz
#bzip2+gzip+xz(对于压缩工具都可通过加 -k保留原文件)
bzip2 文件;将单个文件进行压缩,不会保存原文件
gzip 文件;对单个文件进行压缩,会保存原文件
xz 文件;和bzip2类似,但速度更快
解压:
tar -z/j/Jxvf 文件包.tar.gz/bz2/xz;将tar打包的压缩文件解压
bzip2/gzip/xz -d 压缩文件;解压压缩包不保留压缩包
bzip2/gzip/xz -dk(-d -k) 压缩文件;解压后保留压缩包
gunzip == gzip -d,bunzip2 == bzip2 -d;
gunzip/bunzip2 压缩文件 == bzip2/gzip -d 压缩文件;
#rar
rar a 文件名+.rar 目录;将文件压缩成rar并放进目录
rar x 压缩文件;解压文件
#find
find 起始目录 -name '文件名'/文件名(如果用通配符之类的符号就必须引号包裹)
find 起始目录 -size +(大于)/-(小于) 数值 单位c(字节)k(小写表示kb)/M(mb)/G(gb)
#grep
grep -n(显示行号) -E(可识别执行*，|等特殊符号) "查找关键" 文件名(相对/绝对路径)
#wc
wc -c(字节) -l(行数) -w(单词数) -m(字符数) 路径
#ln
ln -s 文件/文件夹(路径) 软链接名(不可用同名文件/文件夹,容易出问题)
软链接相当于快捷方式,指向绑定的文件/文件夹
#Ps
ps -e(显示所有进程) -f(显示所有信息) 显示当前进程